{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:recommended"
  ],
  "labels": ["dependencies"],
  "pre-commit": { "enabled": true },
  "minimumReleaseAge": "14 days",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "priority:high"],
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Pin GitHub Actions to SHA and auto-merge patch/minor (supply-chain hygiene)",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true,
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "description": "Security updates - immediate, no release-age wait",
      "matchCategories": ["security"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "labels": ["security", "priority:high"],
      "prPriority": 10
    },
    {
      "description": "Major updates - never auto-merge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["breaking-change"],
      "prPriority": -1
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/vendor/**", "staging/**"]
}
