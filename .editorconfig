# Consistent formatting across the polyglot repo (md / yaml / sh / py / json).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,sh}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # two trailing spaces = hard line break

[Makefile]
indent_style = tab
