# Local-Offload Chassis — environment reference (TEMPLATE; copy to .env, never commit real values).
# The chassis reads endpoints/models from a profiles.json (see local_offload/profiles/), NOT from env;
# these vars only configure the shim runtime + the dogfood smoke. No secrets or hosts/IPs belong here.

# --- shim runtime (local_offload.shim.run) ---
WAVE_PROXY_OFFLOAD=0            # 1 = serve trivial turns locally; 0 = passthrough + measure (safe default)
WAVE_PROFILE=Fast              # default profile name from your profiles.json
WAVE_PROXY_LOG=proxy.jsonl     # JSONL decision log path
WAVE_PROXY_PORT=8088           # Anthropic frontend (Claude Code) port
WAVE_OAI_PORT=8090             # OpenAI frontend (Codex/Cursor/aider) port
WAVE_OLLAMA_PORT=11434         # Ollama frontend (Cline/Kilo/Droid) port

# --- frontier backstop (only used when a profile escalates to a hosted endpoint) ---
# The endpoint's api_key_env in profiles.json names the var; the VALUE lives in your env, not here.
# ANTHROPIC_API_KEY=

# --- e2e dogfood smoke (local_offload/examples/e2e-smoke.sh) ---
WAVE_SMOKE_ENDPOINT=http://127.0.0.1:11434   # your local backend (Ollama/vLLM/llama.cpp). Override per-run.
WAVE_SMOKE_MODEL=llama3.2                     # a model the backend actually has
