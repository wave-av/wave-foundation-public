    "Heavy": {
      "temperature": 0.7,
      "max_tokens": 8192,
      "timeout_s": 180,
      "endpoint": "local-heavy",
      "fallback": ["Frontier"]
    },
    "Code": {
      "temperature": 0.2,
      "max_tokens": 4096,
      "timeout_s": 120,
      "endpoint": "local",
      "fallback": ["Heavy", "Frontier"]
    },
    "Frontier": {
      "_comment": "frameworks/claude-api: claude-opus-4-8 REJECTS temperature/top_p/top_k (HTTP 400) — no temperature here; steer via output_config.effort instead.",
      "effort": "high",
      "max_tokens": 8192,
      "timeout_s": 120,
      "endpoint": "frontier",
      "fallback": []
    }
  }
}
