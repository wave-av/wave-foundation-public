{
  "_comment": "Default profiles for the local-offload chassis. TEMPLATE — a spoke copies this into its own repo and overrides models/base_urls. NEVER put internal WAVE hosts/IPs or key values here; local endpoints default to 127.0.0.1, hosted keys come from env. Fallback chain realises HARVEST delta #1: local -> Heavy(local) -> frontier(hosted).",
  "endpoints": {
    "local": {
      "base_url": "http://127.0.0.1:11434",
      "api_style": "ollama",
      "model": "qwen2.5-coder:7b",
      "api_key_env": null
    },
    "local-heavy": {
      "base_url": "http://127.0.0.1:11434",
      "api_style": "ollama",
      "model": "qwen2.5-coder:32b",
      "api_key_env": null
    },
    "frontier": {
      "base_url": "https://api.anthropic.com",
      "api_style": "anthropic",
      "model": "claude-opus-4-8",
      "api_key_env": "ANTHROPIC_API_KEY"
    }
  },
  "profiles": {
    "Fast": {
      "temperature": 0.25,
      "max_tokens": 1024,
      "timeout_s": 30,
      "endpoint": "local",
      "fallback": ["Heavy", "Frontier"]
    },
    "Expert": {
      "temperature": 0.5,
      "max_tokens": 4096,
      "timeout_s": 120,
      "endpoint": "local-heavy",
      "fallback": ["Frontier"]
