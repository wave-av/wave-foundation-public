    "Review": {"temperature": 0.1, "max_tokens": 2048, "timeout_s": 90, "endpoint": "local-heavy", "fallback": ["Frontier"]},
    "Frontier": {"temperature": 0.5, "max_tokens": 8192, "endpoint": "frontier", "fallback": []}
  }
