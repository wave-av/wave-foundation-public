          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Held by design (24h)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"dogfood\"} | json | status=\"hold\" [24h]))",
          "legendFormat": "held",
          "refId": "A"
        }
