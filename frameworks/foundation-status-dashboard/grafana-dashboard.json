    },
    {
      "type": "stat",
      "id": 2,
      "title": "Gates failed (24h)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"dogfood\"} | json | status=\"fail\" [24h]))",
          "legendFormat": "failed",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
