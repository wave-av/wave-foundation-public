    {
      "type": "timeseries",
      "id": 4,
      "title": "Gate pass rate (30d)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "sum by (gate) (count_over_time({source=\"dogfood\"} | json | status=\"pass\" [1h]))",
          "legendFormat": "{{gate}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "row",
      "id": 101,
      "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "p95 gate duration (ms)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "quantile_over_time(0.95, {source=\"dogfood\"} | json | unwrap duration_ms [1h]) by (gate)",
          "legendFormat": "{{gate}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }
    },
    {
      "type": "table",
      "id": 6,
      "title": "Slowest 10 gates (p95, 7d)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "topk(10, quantile_over_time(0.95, {source=\"dogfood\"} | json | unwrap duration_ms [7d]) by (gate))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Improvement loop",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Improvement queue depth",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "last_over_time({source=\"improvement-queue\"} | json | unwrap depth [1h])",
          "legendFormat": "queue",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 23 }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Findings auto-queued (7d)",
      "datasource": { "type": "loki", "uid": "loki-dogfood" },
      "targets": [
        {
          "expr": "sum by (channel) (count_over_time({source=\"improvement-loop\"} | json | event=\"queued\" [1h]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 23 }
    }
